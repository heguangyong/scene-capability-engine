      "properties": {
        "mode": {
          "const": "capability-register"
        },
        "template_id": {
          "type": "string"
        },
        "output_dir": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ontology_core": {
          "$ref": "#/definitions/ontology_core"
        }
      },
      "additionalProperties": false
    },
