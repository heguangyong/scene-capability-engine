      "type": "object",
      "required": [
        "ready",
        "coverage_ratio",
        "coverage_percent",
        "missing",
        "missing_labels",
        "triads"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "coverage_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "coverage_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "triads": {
          "type": "object",
          "required": [
            "entity_relation",
            "business_rules",
            "decision_strategy"
          ],
          "properties": {
            "entity_relation": {
              "type": "boolean"
            },
            "business_rules": {
              "type": "boolean"
            },
            "decision_strategy": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
