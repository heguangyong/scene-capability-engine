          "properties": {
            "mode": {
              "const": "capability-template"
            },
            "template_id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "category": {
              "type": "string"
            },
            "template_type": {
              "const": "capability-template"
            },
            "scene_id": {
              "type": "string"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
