        "mode",
        "scene_id",
        "generated_at",
        "source",
        "specs",
        "summary",
        "ontology_scope",
        "ontology_core"
      ],
      "properties": {
        "mode": {
          "const": "capability-extract"
        },
        "scene_id": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "output_file": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "required": [
            "scene_index_source",
            "spec_count"
          ],
          "properties": {
            "scene_index_source": {
              "type": "string"
            },
            "spec_count": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "specs": {
          "type": "array",
