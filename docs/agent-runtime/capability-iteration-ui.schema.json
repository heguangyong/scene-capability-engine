            "ontology_scope": {
              "$ref": "#/definitions/ontology_scope"
            },
            "created_at": {
              "type": "string"
            },
            "source_candidate": {
              "type": [
                "object",
                "null"
              ]
            },
            "ontology_core": {
              "$ref": "#/definitions/ontology_core"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "registry": {
      "type": "object",
      "required": [
        "mode",
        "template_id",
        "output_dir",
        "files",
        "ontology_core"
