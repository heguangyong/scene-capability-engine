          "properties": {
            "entity_relation": {
              "type": "object",
              "required": [
                "required_fields",
                "entity_count",
                "relation_count",
                "passed"
              ],
              "properties": {
                "required_fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "entity_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "relation_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "passed": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "business_rules": {
              "type": "object",
              "required": [
                "required_fields",
                "count",
                "passed"
              ],
              "properties": {
                "required_fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "count": {
                  "type": "integer",
                  "minimum": 0
                },
                "passed": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "decision_strategy": {
              "type": "object",
              "required": [
                "required_fields",
                "count",
                "passed"
              ],
              "properties": {
                "required_fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "count": {
                  "type": "integer",
                  "minimum": 0
                },
                "passed": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "passed_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_count": {
          "type": "integer",
          "minimum": 0
        },
        "coverage_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ready": {
          "type": "boolean"
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
