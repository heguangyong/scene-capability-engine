    "score": {
      "type": "object",
      "required": [
        "mode",
        "scene_id",
        "generated_at",
        "input",
        "scores"
      ],
      "properties": {
        "mode": {
          "const": "capability-score"
        },
        "scene_id": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "input": {
          "type": "string"
        },
        "output_file": {
          "type": "string"
        },
        "scores": {
          "type": "object",
          "required": [
            "completion_rate",
            "reuse_score",
            "stability_score",
            "risk_score",
            "ontology_core_score",
            "ontology_core",
            "value_score"
          ],
          "properties": {
            "completion_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "reuse_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "stability_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "risk_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "value_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "ontology_core_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "ontology_core": {
              "$ref": "#/definitions/ontology_core"
            }
          },
          "additionalProperties": false
        },
        "summary": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "mapping": {
      "type": "object",
      "required": [
        "mode",
        "scene_id",
        "generated_at",
        "input",
        "template"
      ],
      "properties": {
        "mode": {
          "const": "capability-map"
        },
        "scene_id": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "input": {
          "type": "string"
        },
        "mapping": {
          "type": [
            "string",
            "null"
          ]
        },
        "output_file": {
          "type": "string"
        },
        "template": {
          "type": "object",
          "required": [
            "mode",
            "template_id",
            "name",
            "description",
            "category",
            "template_type",
            "scene_id",
            "ontology_scope",
            "created_at",
            "ontology_core"
