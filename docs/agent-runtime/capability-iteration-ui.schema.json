            "type": "object",
            "required": [
              "spec_id",
              "tasks_path",
              "task_summary"
            ],
            "properties": {
              "spec_id": {
                "type": "string"
              },
              "tasks_path": {
                "type": "string"
              },
              "task_error": {
                "type": "string"
              },
              "task_summary": {
                "type": "object",
                "required": [
                  "total",
                  "completed",
                  "in_progress",
                  "queued",
                  "not_started",
                  "unknown"
                ],
                "properties": {
                  "total": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "completed": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "in_progress": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "queued": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "not_started": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "unknown": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "additionalProperties": false
              },
              "task_sample": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "title",
                    "status"
                  ],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "ontology_scope": {
                "$ref": "#/definitions/ontology_scope"
              },
              "ontology_source": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "ontology_error": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "summary": {
          "type": "object",
          "required": [
            "spec_count",
            "task_total",
            "task_completed",
            "task_pending",
            "ontology_triads_ready",
            "ontology_triads_coverage_ratio",
            "ontology_missing_triads"
          ],
          "properties": {
            "spec_count": {
              "type": "integer",
              "minimum": 0
            },
            "task_total": {
              "type": "integer",
              "minimum": 0
            },
            "task_completed": {
              "type": "integer",
              "minimum": 0
            },
            "task_pending": {
              "type": "integer",
              "minimum": 0
            },
            "ontology_triads_ready": {
              "type": "boolean"
            },
            "ontology_triads_coverage_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "ontology_missing_triads": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "ontology_scope": {
          "$ref": "#/definitions/ontology_scope"
        },
        "ontology_core": {
          "$ref": "#/definitions/ontology_core"
        }
