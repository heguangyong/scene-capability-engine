        "relations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "business_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
